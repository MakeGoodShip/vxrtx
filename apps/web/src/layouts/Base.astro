---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "vxrtx — AI-powered tab and bookmark organization",
  description = "Organize your browser tabs and bookmarks with AI. Privacy-first, with local and cloud options.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-coal text-zinc-100 antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/globals.css";
</style>
