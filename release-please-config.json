{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "apps/extension": {
      "release-type": "node",
      "component": "extension",
      "bump-minor-pre-major": true,
      "extra-files": [
        {
          "type": "json",
          "path": "public/manifest.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
