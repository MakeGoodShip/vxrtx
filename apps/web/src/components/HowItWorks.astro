---
---

<section class="relative px-6 py-32 md:px-12 lg:px-20 border-t border-zinc-800/40">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16">
      <p
        class="mb-3 text-[10px] uppercase tracking-[0.25em] text-brand-400"
        style="font-family: var(--font-family-mono);"
      >How it works</p>
    </div>

    <div class="grid gap-px bg-zinc-800/30 md:grid-cols-3 rounded-lg overflow-hidden">
      <div class="bg-coal p-8 md:p-10">
        <span class="block text-[64px] font-800 leading-none text-zinc-800/80" style="font-family: var(--font-family-display);">1</span>
        <h3 class="mt-4 text-lg font-600 text-white" style="font-family: var(--font-family-display);">Install</h3>
        <p class="mt-2 text-sm text-zinc-500">Add vxrtx from the Chrome Web Store. No account needed. No sign-up.</p>
      </div>
      <div class="bg-coal p-8 md:p-10">
        <span class="block text-[64px] font-800 leading-none text-zinc-800/80" style="font-family: var(--font-family-display);">2</span>
        <h3 class="mt-4 text-lg font-600 text-white" style="font-family: var(--font-family-display);">Open</h3>
        <p class="mt-2 text-sm text-zinc-500">
          <kbd class="rounded bg-surface-raised px-1.5 py-0.5 text-[11px] text-zinc-400" style="font-family: var(--font-family-mono);">Cmd+Shift+V</kbd>
          opens the side panel.
        </p>
      </div>
      <div class="bg-coal p-8 md:p-10">
        <span class="block text-[64px] font-800 leading-none text-zinc-800/80" style="font-family: var(--font-family-display);">3</span>
        <h3 class="mt-4 text-lg font-600 text-white" style="font-family: var(--font-family-display);">Organize</h3>
        <p class="mt-2 text-sm text-zinc-500">Choose your privacy tier. Hit Organize. Preview the suggestions. Apply.</p>
      </div>
    </div>
  </div>
</section>
