---
const providers = [
  { name: "OpenRouter", tag: "cloud", desc: "Claude, GPT-4o, Llama, Gemini — 100+ models, one key" },
  { name: "Anthropic", tag: "cloud", desc: "Direct Claude API with your own key" },
  { name: "OpenAI", tag: "cloud", desc: "Direct GPT API with your own key" },
  { name: "Ollama", tag: "local", desc: "Llama, Mistral, Gemma, Phi — runs on your machine" },
  { name: "Chrome AI", tag: "device", desc: "Gemini Nano on-device, no key needed (Chrome 138+)" },
  { name: "Rules", tag: "zero-ai", desc: "Domain-based grouping, instant, no model required" },
];
---

<section class="relative px-6 py-32 md:px-12 lg:px-20">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-16 lg:grid-cols-[1fr_1fr]">
      <div>
        <p
          class="mb-3 text-[10px] uppercase tracking-[0.25em] text-brand-400"
          style="font-family: var(--font-family-mono);"
        >Providers</p>
        <h2
          class="text-[clamp(1.8rem,4vw,3rem)] font-700 leading-[1.1] tracking-[-0.02em] text-white"
          style="font-family: var(--font-family-display);"
        >
          Use whatever<br/>works for you
        </h2>
        <p class="mt-4 max-w-sm text-zinc-500">
          Cloud, local, on-device, or no AI at all. Bring your own API key — there's no shared key, no middleman, no subscription.
        </p>
      </div>

      <div class="space-y-1">
        {providers.map((p) => (
          <div class="group flex items-center gap-4 rounded-md px-4 py-3 transition-colors hover:bg-surface-raised">
            <span
              class="inline-block w-16 text-[9px] uppercase tracking-[0.15em] text-zinc-600"
              style="font-family: var(--font-family-mono);"
            >{p.tag}</span>
            <span class="w-28 text-sm font-600 text-white shrink-0">{p.name}</span>
            <span class="text-sm text-zinc-500">{p.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
