{
  "name": "vxrtx",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "dev:extension": "pnpm --filter @vxrtx/extension dev",
    "dev:ext": "pnpm --filter @vxrtx/extension dev",
    "dev:web": "pnpm --filter @vxrtx/web dev",
    "dev:docs": "pnpm --filter @vxrtx/docs dev",
    "build:extension": "pnpm --filter @vxrtx/extension build",
    "build:ext": "pnpm --filter @vxrtx/extension build",
    "build:web": "pnpm --filter @vxrtx/web build",
    "build:docs": "pnpm --filter @vxrtx/docs build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "lefthook": "^1.11.0",
    "turbo": "^2.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp"
    ]
  }
}
